APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CHAT_ATTACHMENTS_DISK=public

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail. Production uses Resend for platform transactional email — set
# MAIL_MAILER=resend and the RESEND_* keys below. Leave as "log" for local dev.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Resend — platform transactional email (verification, password reset, lead
# notifications). Paste the real key only into the LIVE server .env; never
# commit it. RESEND_FROM_* define the default platform sender identity.
RESEND_API_KEY=
RESEND_FROM_EMAIL=updates@m.agentsbunny.com
RESEND_FROM_NAME="Agents Bunny Updates"
# Svix signing secret from Resend → Webhooks (for /api/webhooks/resend).
# Paste the real secret only into the live .env; never commit it.
RESEND_WEBHOOK_SECRET=

# Per-user sender aliases: {alias}.updates@RESEND_SENDER_DOMAIN. The default
# sender is used when a user has no alias. Set RESEND_DOMAIN_VERIFIED=false to
# HALT all platform-domain sends while the domain is being verified in Resend
# (branded sends from a user's own domain are unaffected).
RESEND_SENDER_DOMAIN=m.agentsbunny.com
RESEND_DEFAULT_SENDER=updates@m.agentsbunny.com
RESEND_DEFAULT_SENDER_NAME="Agents Bunny Updates"
RESEND_DOMAIN_VERIFIED=true

# Resend quota categories. Property alerts always count; auth/verification/
# password-reset/admin updates and lead/visitor notifications never do; Gmail/
# Outlook inbox mail never touches Resend. Action-plan + automation are
# configurable (defaults below; client requirements conflict).
RESEND_QUOTA_ACTION_PLAN_EMAILS=false
RESEND_QUOTA_AUTOMATION_EMAILS=false
RESEND_PROPERTY_ALERT_MONTHLY_INCLUDED=10000
RESEND_PROPERTY_ALERT_OVERAGE_PER_1000=1.00

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback
# Gmail inbox connection (Email Settings → Connect Gmail). Path is appended to APP_URL.
GOOGLE_GMAIL_REDIRECT_URI=/crm/email/oauth/google/callback

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_IDX_LICENSE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Bridge Data Output (MLS)
BRIDGE_SERVER_TOKEN=
BRIDGE_BROWSER_TOKEN=
BRIDGE_CLIENT_ID=
BRIDGE_CLIENT_SECRET=

# Realtyna / RealtyFeed (MLS).
# One account proxies access to N MLSes. Each MLS in our catalog stores its
# OriginatingSystemName in mls_providers.data_source_config to filter results.
REALTYNA_CLIENT_ID=
REALTYNA_CLIENT_SECRET=
REALTYNA_API_KEY=
REALTYNA_API_BASE=https://api.realtyfeed.com

# Telnyx (telephony: phone numbers, SMS, voice/WebRTC, 10DLC)
# Paste real values ONLY in the live .env — never here, never committed.
# After setting them on the server run: php artisan config:clear
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
# Public key from Mission Control → Account → Keys & Credentials (Ed25519 webhook verification).
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
# Voice → Call Control App ID (programmatic outbound calls + voicedrop).
TELNYX_CALL_CONTROL_APP_ID=
# Credential/SIP connection ID for the in-browser WebRTC dialer (auto-created on first use if blank).
TELNYX_SIP_CONNECTION_ID=

# Gemini AI
GEMINI_API_KEY=

# Reverb (WebSocket)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Google Maps browser key for the public property-search map (restrict by HTTP referrer)
GOOGLE_MAPS_API_KEY=
# Optional: keep the key's domain (HTTP-referrer) restriction but let the system auto-add
# every connected customer domain, so Maps/Places work on any website without lifting the
# restriction. Set the key's full resource name + a service-account JSON path with the
# "API Keys Admin" role (leave both blank to manage referrers by hand in the Cloud Console).
GOOGLE_MAPS_KEY_RESOURCE=
GOOGLE_MAPS_KEY_CREDENTIALS=

PROPERTY_SEARCH_MOCK=false
